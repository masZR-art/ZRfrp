<Window x:Class="FrpDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FrpDesktop"
        Title="ZRfrp"
        Width="1120"
        Height="720"
        MinWidth="1040"
        MinHeight="660"
        WindowStyle="None"
        ResizeMode="NoResize"
        Icon="Assets/AppIcon.ico"
        Background="{StaticResource SurfaceBrush}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#07111C"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="16,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Width="22"
                           Height="22"
                           Source="Assets/AppLogo32.png"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"
                           Margin="0,0,10,0" />
                    <TextBlock Text="ZRfrp"
                               Foreground="White"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource WindowButton}"
                            Click="MinimizeButton_Click">
                        <Border Width="10"
                                Height="1"
                                Background="#B8C7D8"
                                SnapsToDevicePixels="True" />
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Content="□"
                            Style="{StaticResource WindowButton}"
                            Click="MaximizeButton_Click" />
                    <Button Content="×"
                            Style="{StaticResource WindowButton}"
                            Foreground="#F6B4B4"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="244" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBrush}"
                    Padding="18,16">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <Border Background="{StaticResource SidebarPanelBrush}"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="节点"
                                           Foreground="White"
                                           FontSize="22"
                                           FontWeight="Bold" />
                                <TextBlock Text="右键节点进行设置或删除"
                                           Foreground="#91A4B8"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>

                        <Button Content="+ 新增节点"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalContentAlignment="Center"
                                Margin="0,0,0,16"
                                Click="AddProfile_Click" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom"
                                Margin="2,14,2,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Width="40"
                                    Height="40"
                                    MinWidth="40"
                                    Padding="0"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource SecondaryButton}"
                                    ToolTip="软件设置"
                                    Click="OpenAppSettings_Click">
                                <TextBlock Text="&#xE90F;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="18"
                                           Foreground="{StaticResource InkBrush}" />
                            </Button>
                            <Button x:Name="TestAllLatencyButton"
                                    Width="40"
                                    Height="40"
                                    MinWidth="40"
                                    Padding="0"
                                    Style="{StaticResource SecondaryButton}"
                                    FocusVisualStyle="{x:Null}"
                                    Margin="10,0,0,0"
                                    ToolTip="测速全部节点"
                                    Click="TestAllLatencyButton_Click">
                                <TextBlock Text="⟳"
                                           FontSize="21"
                                           FontWeight="SemiBold"
                                           Foreground="#E8F2FF"
                                           RenderTransformOrigin="0.5,0.5"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0,-1,0,0">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="TestAllLatencyIconRotate" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Button>
                        </StackPanel>
                        <Button x:Name="VersionButton"
                                Content="ZRfrp v2.0.3"
                                Style="{StaticResource GhostButton}"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Margin="0,10,0,0"
                                Click="VersionButton_Click" />
                        <TextBlock Text="配置保存在当前 Windows 用户目录"
                                   Foreground="#7E91A7"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Margin="0,10,0,0" />
                    </StackPanel>

                    <ListBox x:Name="ProfilesList"
                             SelectionChanged="ProfilesList_SelectionChanged"
                             PreviewMouseRightButtonDown="ProfilesList_PreviewMouseRightButtonDown"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             FontFamily="Microsoft YaHei UI"
                             FontSize="14"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="13"
                                        Margin="0,0,0,8"
                                        CornerRadius="8"
                                        Background="Transparent">
                                    <Border.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="节点设置" Click="ProfileSettingsMenu_Click" />
                                            <MenuItem Header="删除节点" Click="DeleteProfileMenu_Click" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,8,0" />
                                        <Button Grid.Column="1"
                                                Grid.RowSpan="2"
                                                Style="{StaticResource TextOnlyButton}"
                                                Padding="4,0"
                                                Cursor="Hand"
                                                ToolTip="重新测速"
                                                Click="RetestProfileLatency_Click">
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="⟳"
                                                           FontSize="11"
                                                           Margin="0,0,4,0"
                                                           Foreground="#60A5FA"
                                                           RenderTransformOrigin="0.5,0.5"
                                                           Visibility="{Binding IsLatencyTesting, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform />
                                                    </TextBlock.RenderTransform>
                                                    <TextBlock.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever">
                                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle"
                                                                                     From="0"
                                                                                     To="360"
                                                                                     Duration="0:0:0.9" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </TextBlock.Triggers>
                                                </TextBlock>
                                                <TextBlock Text="{Binding LatencyText}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           TextDecorations="Underline"
                                                           Foreground="{Binding LatencyText, Converter={StaticResource LatencyBrushConverter}}" />
                                            </StackPanel>
                                        </Button>
                                        <StackPanel Grid.Row="1"
                                                    Orientation="Horizontal"
                                                    Margin="0,5,0,0">
                                            <TextBlock Text="{Binding ServerAddr}"
                                                       Foreground="#A9B8C9"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="142" />
                                            <TextBlock Text=":"
                                                       Foreground="#A9B8C9"
                                                       FontSize="12" />
                                            <TextBlock Text="{Binding ServerPort}"
                                                       Foreground="#A9B8C9"
                                                       FontSize="12" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1"
                  Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="118" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="168" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        CornerRadius="8"
                        Padding="20"
                        Background="#101B28"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="HeaderTitle"
                                       Text="默认连接"
                                       Foreground="White"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Ellipse x:Name="StatusDot"
                                         Width="10"
                                         Height="10"
                                         Fill="#94A3B8"
                                         Margin="0,5,8,0" />
                                <TextBlock x:Name="StatusText"
                                           Text="未运行"
                                           Foreground="#D8E3EF"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="  /  "
                                           Foreground="#728196" />
                                <TextBlock x:Name="TunnelSummaryText"
                                           Text="0 个隧道"
                                           Foreground="#B8C7D8" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <TextBlock Text="服务端 "
                                           Foreground="#7E91A7" />
                                <TextBlock x:Name="ServerSummaryText"
                                           Text="未配置"
                                           Foreground="#D8E3EF"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="    配置 "
                                           Foreground="#7E91A7" />
                                <TextBlock x:Name="GeneratedSummaryText"
                                           Text="等待生成"
                                           Foreground="#D8E3EF"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="360" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top">
                            <Button x:Name="ConnectionButton"
                                    Content="启动连接"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,10,0"
                                    Click="ConnectionButton_Click" />
                            <Button Content="导入配置"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="ImportButton_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="18"
                        Margin="0,18,0,18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="隧道"
                                           FontSize="20"
                                           FontWeight="Bold" />
                                <TextBlock Text="右键隧道进行编辑或移除，卡片右侧可快速启停。"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="+ 新建隧道"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="AddProxy_Click" />
                        </Grid>

                        <ListBox x:Name="ProxiesList"
                                 Grid.Row="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 PreviewMouseRightButtonDown="ProxiesList_PreviewMouseRightButtonDown"
                                 MouseDoubleClick="ProxiesList_MouseDoubleClick"
                                 ScrollViewer.CanContentScroll="False"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 local:SmoothScroll.Enabled="True">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,12,12" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Chrome"
                                                        Background="Transparent"
                                                        CornerRadius="8">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background" Value="Transparent" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Chrome" Property="Background" Value="#0F1D2D" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Height="112"
                                            Padding="14"
                                            Background="#0D1826"
                                            BorderBrush="#203349"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Border.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="编辑隧道" Click="EditProxyMenu_Click" />
                                                <MenuItem Header="移除隧道" Click="RemoveProxyMenu_Click" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="White"
                                                               FontSize="18"
                                                               FontWeight="Bold"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="190" />
                                                    <Border Background="#153D34"
                                                            CornerRadius="8"
                                                            Padding="9,3"
                                                            Margin="10,1,0,0">
                                                        <TextBlock Text="{Binding Type}"
                                                                   Foreground="#A8F3D6"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold" />
                                                    </Border>
                                                </StackPanel>

                                                <CheckBox Grid.Column="1"
                                                          Style="{StaticResource SwitchCheckBox}"
                                                          IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                          Checked="ProxyEnabledChanged"
                                                          Unchecked="ProxyEnabledChanged"
                                                          VerticalAlignment="Top"
                                                          Margin="12,0,0,0" />
                                            </Grid>

                                            <Grid Grid.Row="1"
                                                  Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,0,10,8">
                                                    <TextBlock Text="本地"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontSize="12"
                                                               Width="34" />
                                                    <TextBlock Foreground="#D8E3EF"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0}:{1}">
                                                                    <Binding Path="LocalIP" />
                                                                    <Binding Path="LocalPort" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Margin="0,0,0,8">
                                                    <TextBlock Text="远程"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontSize="12"
                                                               Width="34" />
                                                    <TextBlock Text="{Binding RemotePort}"
                                                               Foreground="#D8E3EF"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>

                                                <StackPanel Grid.Row="1"
                                                            Orientation="Horizontal"
                                                            Margin="0,0,10,0">
                                                    <TextBlock Text="域名"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontSize="12"
                                                               Width="34" />
                                                    <TextBlock Text="{Binding CustomDomains, Converter={StaticResource EmptyToPlaceholderConverter}}"
                                                               Foreground="#D8E3EF"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>

                                                <StackPanel Grid.Row="1"
                                                            Grid.Column="1"
                                                            Orientation="Horizontal">
                                                    <TextBlock Text="状态"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontSize="12"
                                                               Width="34" />
                                                    <TextBlock Foreground="#D8E3EF"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="停用" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                                            <Setter Property="Text" Value="启用" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{StaticResource ConsoleBrush}"
                        CornerRadius="8"
                        Padding="16"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="运行日志"
                                           Foreground="#E8EEF5"
                                           FontWeight="SemiBold"
                                           FontSize="15" />
                                <TextBlock Text="  实时输出 frpc 状态"
                                           Foreground="#7E8FA5" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="清空"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="30"
                                    MinWidth="66"
                                    Click="ClearLog_Click" />
                        </Grid>

                        <RichTextBox x:Name="LogTextBox"
                                     Grid.Row="1"
                                     Height="Auto"
                                     MinHeight="0"
                                     VerticalAlignment="Stretch"
                                     Background="{StaticResource ConsoleBrush}"
                                     BorderThickness="0"
                                     Padding="0"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Foreground="#D1FAE5"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     IsDocumentEnabled="True"
                                     IsReadOnly="True"
                                     local:SmoothScroll.Enabled="True">
                            <FlowDocument x:Name="LogDocument"
                                          PagePadding="0"
                                          FontFamily="Consolas"
                                          FontSize="12">
                                <Paragraph Margin="0" />
                            </FlowDocument>
                        </RichTextBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border x:Name="ToastPanel"
                Grid.RowSpan="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,30,28"
                Background="#13263A"
                BorderBrush="#2F4B68"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,10"
                Visibility="Collapsed">
            <TextBlock x:Name="ToastText"
                       Text="地址已复制到剪贴板"
                       Foreground="#D8EAFE"
                       FontWeight="SemiBold" />
        </Border>

        <Grid x:Name="DialogOverlay"
              Grid.RowSpan="2"
              Background="#AA020812"
              Visibility="Collapsed">
            <Border x:Name="ConfirmDialogPanel"
                    Width="390"
                    Background="#101B28"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="ConfirmTitleText"
                               Text="确认操作"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold" />
                    <TextBlock x:Name="ConfirmMessageText"
                               Text="是否继续？"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,12,0,24" />
                    <UniformGrid Columns="2">
                        <Button Content="取消"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,7,0"
                                Click="ConfirmCancel_Click" />
                        <Button Content="确认"
                                Style="{StaticResource DangerButton}"
                                Margin="7,0,0,0"
                                Click="ConfirmAccept_Click" />
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border x:Name="NodeSettingsDialogPanel"
                    Width="520"
                    Background="#101B28"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
                <Border.RenderTransform>
                    <TranslateTransform />
                </Border.RenderTransform>
                <StackPanel>
                    <Grid Tag="{Binding ElementName=NodeSettingsDialogPanel}"
                          Cursor="SizeAll"
                          MouseLeftButtonDown="FloatingPanelHeader_MouseLeftButtonDown"
                          Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="节点设置"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="Bold" />
                            <TextBlock Text="修改服务端连接和本机 frpc 路径。"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="×"
                                Width="34"
                                Height="30"
                                MinWidth="34"
                                Padding="0"
                                Style="{StaticResource WindowButton}"
                                Foreground="#F6B4B4"
                                ToolTip="关闭"
                                Click="FloatingPanelClose_Click" />
                    </Grid>
                    <TextBlock Text="连接名称" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="NodeNameTextBox" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="130" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="服务端地址" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="NodeServerAddrTextBox" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="端口" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="NodeServerPortTextBox" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Token" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <PasswordBox x:Name="NodeTokenPasswordBox" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="ZRfrp Server 托管" Foreground="White" FontWeight="SemiBold" />
                            <TextBlock Text="由服务端分配并锁定远程端口"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12" />
                        </StackPanel>
                        <CheckBox x:Name="NodeServerManagedCheckBox"
                                  Grid.Column="1"
                                  Style="{StaticResource SwitchCheckBox}"
                                  VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="控制面板地址" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="NodeControlApiUrlTextBox"
                             ToolTip="例如 https://frp.example.com"
                             Margin="0,0,0,12" />
                    <TextBlock Text="客户端 API Key" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <PasswordBox x:Name="NodeControlApiKeyPasswordBox" Margin="0,0,0,12" />
                    <TextBlock Text="frpc.exe 路径" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="82" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NodeFrpcPathTextBox" />
                        <Button Grid.Column="1"
                                Content="选择"
                                Style="{StaticResource SecondaryButton}"
                                Margin="8,0,0,0"
                                Click="BrowseFrpcButton_Click" />
                    </Grid>
                    <TextBlock Text="生成配置文件" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="NodeGeneratedConfigTextBox"
                             IsReadOnly="True"
                             Height="58"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             Margin="0,0,0,8" />
                    <TextBlock x:Name="NodeSettingsErrorText"
                               Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />
                    <UniformGrid Columns="3">
                        <Button Content="打开配置目录"
                                Style="{StaticResource GhostButton}"
                                Margin="0,0,8,0"
                                Click="OpenGeneratedFolder_Click" />
                        <Button Content="取消"
                                Style="{StaticResource SecondaryButton}"
                                Margin="4,0"
                                Click="CancelNodeSettings_Click" />
                        <Button Content="保存节点"
                                Style="{StaticResource PrimaryButton}"
                                Margin="8,0,0,0"
                                Click="SaveNodeSettings_Click" />
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border x:Name="AppSettingsDialogPanel"
                    Width="590"
                    Background="#101B28"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
                <Border.RenderTransform>
                    <TranslateTransform />
                </Border.RenderTransform>
                <StackPanel>
                    <Grid Tag="{Binding ElementName=AppSettingsDialogPanel}"
                          Cursor="SizeAll"
                          MouseLeftButtonDown="FloatingPanelHeader_MouseLeftButtonDown"
                          Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="软件设置"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="Bold" />
                            <TextBlock Text="管理 ZRfrp 使用的本机运行环境。"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="×"
                                Width="34"
                                Height="30"
                                MinWidth="34"
                                Padding="0"
                                Style="{StaticResource WindowButton}"
                                Foreground="#F6B4B4"
                                ToolTip="关闭"
                                Click="FloatingPanelClose_Click" />
                    </Grid>

                    <ScrollViewer MaxHeight="590"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  local:SmoothScroll.Enabled="True">
                    <StackPanel>
                    <Border Background="#0D1826"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="18"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="控制平台账号"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="AccountStatusText"
                                       Text="登录后才能获取服务授权并启动连接。"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       Margin="0,4,0,14" />
                            <TextBlock Text="平台地址" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="PlatformUrlTextBox" Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,6,0">
                                    <TextBlock Text="账号" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                                    <TextBox x:Name="AccountUsernameTextBox" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="密码" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                                    <PasswordBox x:Name="AccountPasswordBox" />
                                </StackPanel>
                            </Grid>
                            <Button Content="登录控制平台"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="AccountLoginButton_Click" />
                        </StackPanel>
                    </Border>
                    <Border Background="#0D1826"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="18">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36"
                                        Height="36"
                                        CornerRadius="8"
                                        Background="{StaticResource AccentSoftBrush}"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="&#xE90F;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="17"
                                               Foreground="#45D3A5"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="客户端 FRP 环境"
                                               Foreground="White"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="自动识别、安装并统一节点使用的 frpc.exe。"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="12"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <Grid Margin="0,18,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="EnvironmentStatusDot"
                                         Width="9"
                                         Height="9"
                                         Fill="#94A3B8"
                                         Margin="0,5,9,0"
                                         VerticalAlignment="Top" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="EnvironmentStatusTitle"
                                               Text="等待检测"
                                               Foreground="{StaticResource InkBrush}"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="EnvironmentStatusDetail"
                                               Text="打开设置后会自动查找本机的 frpc。"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="当前路径"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,0,0,6" />
                            <TextBox x:Name="FrpcEnvironmentPathTextBox"
                                     IsReadOnly="True"
                                     ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />

                            <ProgressBar x:Name="EnvironmentProgressBar"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="0"
                                         Visibility="Collapsed"
                                         Margin="0,14,0,0" />
                            <TextBlock x:Name="EnvironmentProgressText"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       Visibility="Collapsed"
                                       Margin="0,7,0,0" />

                            <UniformGrid Columns="3"
                                         Margin="0,16,0,0">
                                <Button x:Name="DetectFrpcButton"
                                        Content="重新检测"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,7,0"
                                        Click="DetectFrpcButton_Click" />
                                <Button x:Name="ChooseEnvironmentFrpcButton"
                                        Content="选择文件"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="3,0"
                                        Click="ChooseEnvironmentFrpcButton_Click" />
                                <Button x:Name="InstallFrpcButton"
                                        Content="自动下载安装"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="7,0,0,0"
                                        Click="InstallFrpcButton_Click" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Background="#0D1826"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="18"
                            Margin="0,14,0,0">
                        <StackPanel>
                            <StackPanel>
                                <TextBlock Text="网络代理"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="用于软件自动下载和访问发布信息。FRP 连接和 TCP 测速不受影响。"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>

                            <TextBlock Text="代理模式"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,16,0,6" />
                            <ComboBox x:Name="NetworkProxyModeComboBox"
                                      SelectionChanged="NetworkProxyChanged">
                                <ComboBoxItem Content="自动检测系统代理" Tag="system" />
                                <ComboBoxItem Content="不使用代理" Tag="none" />
                                <ComboBoxItem Content="手动设置代理" Tag="manual" />
                            </ComboBox>

                            <StackPanel x:Name="ManualProxyPanel"
                                        Margin="0,14,0,0">
                                <TextBlock Text="代理类型"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,0,0,6" />
                                <ComboBox x:Name="NetworkProxyTypeComboBox"
                                          SelectionChanged="NetworkProxyChanged">
                                    <ComboBoxItem Content="HTTP" />
                                    <ComboBoxItem Content="HTTPS" />
                                    <ComboBoxItem Content="SOCKS4" />
                                    <ComboBoxItem Content="SOCKS5" />
                                </ComboBox>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="主机"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Margin="0,0,0,6" />
                                        <TextBox x:Name="NetworkProxyHostTextBox"
                                                 ToolTip="例如 127.0.0.1"
                                                 TextChanged="NetworkProxyTextChanged" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="端口"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Margin="0,0,0,6" />
                                        <TextBox x:Name="NetworkProxyPortTextBox"
                                                 ToolTip="例如 7890"
                                                 TextChanged="NetworkProxyTextChanged" />
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="用户名"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Margin="0,0,0,6" />
                                        <TextBox x:Name="NetworkProxyUsernameTextBox"
                                                 ToolTip="没有认证可留空"
                                                 TextChanged="NetworkProxyTextChanged" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="密码"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Margin="0,0,0,6" />
                                        <PasswordBox x:Name="NetworkProxyPasswordBox"
                                                     ToolTip="没有认证可留空"
                                                     PasswordChanged="NetworkProxyPasswordChanged" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <Border Background="#0B1421"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,14,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse x:Name="NetworkProxyStatusDot"
                                             Width="8"
                                             Height="8"
                                             Fill="#94A3B8"
                                             Margin="0,5,9,0"
                                             VerticalAlignment="Top" />
                                    <TextBlock x:Name="NetworkProxyStatusText"
                                               Grid.Column="1"
                                               Text="当前不使用代理。"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="#0D1826"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="18"
                            Margin="0,14,0,0">
                        <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="关闭行为"
                                               Foreground="White"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="没有连接运行时，点击关闭按钮直接退出软件。"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <CheckBox x:Name="ExitOnCloseWhenDisconnectedCheckBox"
                                          Grid.Column="1"
                                          Style="{StaticResource SwitchCheckBox}"
                                          VerticalAlignment="Center"
                                          Checked="ExitOnCloseWhenDisconnectedChanged"
                                          Unchecked="ExitOnCloseWhenDisconnectedChanged" />
                            </Grid>
                    </Border>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="下载来源：FRP 官方 GitHub 发布页"
                                   Foreground="#6F839A"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="关闭"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,10,0"
                                Click="CloseAppSettings_Click" />
                        <Button x:Name="ApplyFrpcEnvironmentButton"
                                Grid.Column="2"
                                Content="应用到全部节点"
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="132"
                                Click="ApplyFrpcEnvironmentButton_Click" />
                    </Grid>
                    </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border x:Name="ProxyEditorPanel"
                    Width="520"
                    Background="#101B28"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
                <Border.RenderTransform>
                    <TranslateTransform />
                </Border.RenderTransform>
                <StackPanel>
                    <Grid Tag="{Binding ElementName=ProxyEditorPanel}"
                          Cursor="SizeAll"
                          MouseLeftButtonDown="FloatingPanelHeader_MouseLeftButtonDown"
                          Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="ProxyEditorTitle"
                                       Text="创建隧道"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="Bold" />
                            <TextBlock x:Name="ProxyEditorSubtitle"
                                       Text="选择节点，然后填写本地和远程端口。"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="×"
                                Width="34"
                                Height="30"
                                MinWidth="34"
                                Padding="0"
                                Style="{StaticResource WindowButton}"
                                Foreground="#F6B4B4"
                                ToolTip="关闭"
                                Click="FloatingPanelClose_Click" />
                    </Grid>
                    <TextBlock Text="部署节点" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <ComboBox x:Name="ProxyProfileComboBox"
                              TextSearch.TextPath="Name"
                              SelectionChanged="ProxyProfileComboBox_SelectionChanged"
                              Margin="0,0,0,12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource InkBrush}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="隧道名称" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="ProxyNameTextBox" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="112" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="类型" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                            <ComboBox x:Name="ProxyTypeComboBox">
                                <ComboBoxItem Content="tcp" />
                                <ComboBoxItem Content="udp" />
                                <ComboBoxItem Content="http" />
                                <ComboBoxItem Content="https" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="启用" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                            <CheckBox x:Name="ProxyEnabledCheckBox"
                                      Style="{StaticResource SwitchCheckBox}"
                                      Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="本地 IP" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="ProxyLocalIPTextBox" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="本地端口" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="ProxyLocalPortTextBox" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="远程端口" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="ProxyRemotePortTextBox" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="带宽限制" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="ProxyBandwidthLimitTextBox"
                             ToolTip="留空表示不限速；例如 512KB 或 2MB"
                             Margin="0,0,0,12" />
                    <TextBlock Text="HTTP/HTTPS 域名" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="ProxyCustomDomainsTextBox"
                             Margin="0,0,0,8"
                             ToolTip="多个域名用英文逗号分隔" />
                    <TextBlock x:Name="ProxyEditorErrorText"
                               Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />
                    <UniformGrid Columns="2">
                        <Button Content="取消"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,7,0"
                                Click="CancelProxyEdit_Click" />
                        <Button Content="保存隧道"
                                Style="{StaticResource PrimaryButton}"
                                Margin="7,0,0,0"
                                Click="SaveProxyEdit_Click" />
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
