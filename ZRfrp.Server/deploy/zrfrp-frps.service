[Unit]
Description=ZRfrp managed frps
After=network-online.target zrfrp-server.service
Wants=network-online.target
Requires=zrfrp-server.service

[Service]
Type=simple
User=zrfrp
Group=zrfrp
WorkingDirectory=/opt/zrfrp
ExecStart=/opt/zrfrp/frps -c /etc/zrfrp/frps.toml
Restart=on-failure
RestartSec=3
LimitNOFILE=1048576
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log/zrfrp

[Install]
WantedBy=multi-user.target
